{
  "buildCommand": "npm install && npx vite build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://crm-backend-o0uw.onrender.com/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "build": {
    "env": {
      "VITE_API_URL": "https://crm-backend-o0uw.onrender.com/api/v1",
      "VITE_SOCKET_URL": "https://crm-backend-o0uw.onrender.com",
      "VITE_APP_NAME": "A5X CRM"
    }
  }
}